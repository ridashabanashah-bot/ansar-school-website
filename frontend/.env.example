# Strapi backend URL — public read endpoints
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Optional API token (read-only) for fetching unpublished or restricted content
# Generate in Strapi: Settings → API Tokens → Create new (read-only)
STRAPI_API_TOKEN=

# Site URL — used for canonical/OG tags
NEXT_PUBLIC_SITE_URL=http://localhost:3000
