{
  "kind": "singleType",
  "collectionName": "home_pages",
  "info": {
    "singularName": "home-page",
    "pluralName": "home-pages",
    "displayName": "Home Page",
    "description": "Content for the homepage."
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "heroTitle": { "type": "string", "required": true },
    "heroSubtitle": { "type": "text" },
    "heroImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "introHeading": { "type": "string" },
    "introBody": { "type": "text" },
    "highlights": { "type": "component", "repeatable": true, "component": "shared.highlight" },
    "ctaTitle": { "type": "string" },
    "ctaBody": { "type": "text" },
    "ctaButtonLabel": { "type": "string" },
    "ctaButtonHref": { "type": "string" },
    "heroSlides": { "type": "component", "repeatable": true, "component": "home.hero-slide" },
    "stats": { "type": "component", "repeatable": true, "max": 6, "component": "home.stat" },
    "whyUs": { "type": "component", "repeatable": true, "max": 6, "component": "shared.highlight" },
    "programsHeading": { "type": "string" },
    "programsBody": { "type": "text" },
    "testimonials": { "type": "component", "repeatable": true, "component": "home.testimonial" },
    "ctaBanner": { "type": "component", "repeatable": false, "component": "shared.cta-banner" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" }
  }
}
