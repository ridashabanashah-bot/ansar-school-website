{
  "kind": "singleType",
  "collectionName": "about_pages",
  "info": {
    "singularName": "about-page",
    "pluralName": "about-pages",
    "displayName": "About Page"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true, "default": "About Our School" },
    "vision": { "type": "text" },
    "mission": { "type": "text" },
    "history": { "type": "text" },
    "principalName": { "type": "string" },
    "principalMessage": { "type": "text" },
    "principalPhoto": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" }
  }
}
