    "address": { "type": "text" },
    "facebookUrl": { "type": "string" },
    "instagramUrl": { "type": "string" },
    "youtubeUrl": { "type": "string" },
    "mapEmbedUrl": { "type": "string" },
    "navigation": { "type": "json" },
    "footerNavigation": { "type": "json" },
    "footerAboutBlurb": { "type": "text" },
    "officeHours": { "type": "string" },
