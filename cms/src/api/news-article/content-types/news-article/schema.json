{
  "kind": "collectionType",
  "collectionName": "news_articles",
  "info": {
    "singularName": "news-article",
    "pluralName": "news-articles",
    "displayName": "News Article",
    "description": "School news, announcements, achievements."
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text", "maxLength": 280 },
    "body": { "type": "richtext" },
    "publishedDate": { "type": "datetime" },
    "coverImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" }
  }
}
