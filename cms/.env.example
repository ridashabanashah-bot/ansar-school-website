HOST=0.0.0.0
PORT=1337

# Generate these with: openssl rand -base64 32
APP_KEYS=replace-me-1,replace-me-2
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# Database — defaults to local SQLite file. Strapi Cloud will provide PG vars in prod.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For Postgres in production:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# DATABASE_SSL=true
